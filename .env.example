# App
APP_NAME="Career Alignment Agent Backend"
ENVIRONMENT=development
API_V1_PREFIX=/api/v1
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Database
# Supabase pooled connection example:
# DATABASE_URL=postgresql+psycopg://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
DATABASE_URL=sqlite:///./job_assistance_dev.db
CREATE_DB_ON_STARTUP=true

# Supabase placeholders for future direct Supabase integration.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# LLM / Pydantic AI
# Leave ENABLE_LLM=false until API keys are available. Deterministic dev fallbacks remain active.
ENABLE_LLM=false
OPENAI_API_KEY=
CHEAP_MODEL=openai:gpt-5-nano
RELIABLE_MODEL=openai:gpt-5-nano
WRITING_MODEL=openai:gpt-5-nano
MAX_MODEL_RETRIES=2

# Scraping
HTTP_TIMEOUT_SECONDS=15
MAX_JOB_TEXT_CHARS=50000
JOB_SEARCH_API_URL=
JOB_SEARCH_API_KEY=

# Uploaded source documents
SOURCE_DOCUMENTS_DIR=./artifacts/source_documents
MAX_SOURCE_DOCUMENT_BYTES=10000000
MAX_SOURCE_DOCUMENT_TEXT_CHARS=60000

# Artifacts / LaTeX
ARTIFACTS_DIR=./artifacts
LATEX_ENGINE=pdflatex
LATEX_COMPILE_TIMEOUT_SECONDS=20
